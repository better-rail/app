{
  "name": "better-rail",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "test:e2e": "detox test -c ios.sim.debug",
    "build:e2e": "detox build -c ios.sim.debug",
    "ci:test:e2e": "detox test -c ios.sim.release -l verbose --cleanup",
    "ci:build:e2e": "detox build -c ios.sim.release",
    "compile": "tsc --noEmit -p . --pretty",
    "format": "npm-run-all format:*",
    "format:js": "prettier --write \"**/*.js\"",
    "format:json": "prettier --write \"**/*.json\"",
    "format:md": "prettier --write \"**/*.md\"",
    "format:ts": "prettier --write \"**/*.ts{,x}\"",
    "lint": "eslint index.js app test --fix --ext .js,.ts,.tsx && bun format",
    "test": "bun test",
    "adb": "adb reverse tcp:9090 tcp:9090 && adb reverse tcp:3000 tcp:3000 && adb reverse tcp:9001 tcp:9001 && adb reverse tcp:8081 tcp:8081"
  },
  "dependencies": {
    "@callstack/liquid-glass": "^0.4.3",
    "@expo/react-native-action-sheet": "4.1.1",
    "@expo/ui": "~56.0.18",
    "@notifee/react-native": "9.1.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/push-notification-ios": "1.12.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-native/eslint-config": "0.81.4",
    "@sentry/react-native": "8.15.1",
    "@shopify/flash-list": "2.0.2",
    "axios": "1.4.0",
    "babel-plugin-module-resolver": "5.0.3",
    "burnt": "0.12.2",
    "date-fns": "2.30.0",
    "date-fns-tz": "2.0.0",
    "expo": "56.0.12",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.19",
    "expo-calendar": "~56.0.8",
    "expo-clipboard": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.7",
    "expo-localization": "~56.0.6",
    "expo-network": "~56.0.5",
    "expo-notifications": "~56.0.19",
    "expo-router": "~56.2.11",
    "expo-store-review": "~56.0.3",
    "expo-task-manager": "~56.0.20",
    "expo-updates": "~56.0.19",
    "fuse.js": "6.4.6",
    "i18n-js": "3.8.0",
    "lodash": "4.17.21",
    "posthog-react-native": "^4.39.4",
    "posthog-react-native-session-replay": "^1.5.2",
    "ramda": "0.27.1",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-bouncy-checkbox": "3.0.7",
    "react-native-context-menu-view": "1.21.0",
    "react-native-date-picker": "5.0.12",
    "react-native-default-preference": "1.4.4",
    "react-native-device-info": "10.6.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-haptic-feedback": "2.3.3",
    "react-native-iap": "14.4.25",
    "react-native-inappbrowser-reborn": "3.7.0",
    "react-native-ios-context-menu": "3.1.3",
    "react-native-ios-utilities": "github:dominicstop/react-native-ios-utilities#v5.2.1",
    "react-native-linear-gradient": "2.5.6",
    "react-native-modal-datetime-picker": "18.0.0",
    "react-native-nitro-modules": "^0.31.0",
    "react-native-prompt-android": "1.1.0",
    "react-native-push-notification": "8.1.1",
    "react-native-quick-actions-shortcuts": "1.0.2",
    "react-native-reanimated": "4.3.1",
    "react-native-restart-newarch": "^1.0.85",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-share": "11.0.3",
    "react-native-svg": "15.15.4",
    "react-native-touchable-scale": "2.2.0",
    "react-native-video": "6.16.1",
    "react-native-watch-connectivity": "1.1.0",
    "react-native-worklets": "0.8.3",
    "react-query": "3.39.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/plugin-proposal-optional-catch-binding": "7.18.6",
    "@babel/preset-env": "7.25.3",
    "@babel/runtime": "7.25.0",
    "@bacons/apple-targets": "4.0.7",
    "@types/i18n-js": "3.0.3",
    "@types/lodash": "4.14.194",
    "@types/ramda": "0.27.32",
    "@types/react": "~19.2.14",
    "@types/react-native-push-notification": "8.1.1",
    "@typescript-eslint/eslint-plugin": "5.58.0",
    "@typescript-eslint/parser": "5.58.0",
    "bufferutil": "4.0.2",
    "detox": "20.7.0",
    "eslint": "8.19.0",
    "eslint-config-prettier": "7.0.0",
    "eslint-config-standard": "16.0.2",
    "eslint-plugin-import": "2.22.1",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-promise": "4.2.1",
    "eslint-plugin-react": "7.21.5",
    "eslint-plugin-react-native": "3.10.0",
    "npm-run-all": "4.1.5",
    "postinstall-prepare": "1.0.1",
    "prettier": "2.8.8",
    "react-devtools-core": "4.10.1",
    "react-native-console-time-polyfill": "1.2.3",
    "typescript": "~6.0.3",
    "utf-8-validate": "5.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/node_modules/react-native/jest/setup.js",
      "<rootDir>/test/setup.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/e2e",
      "/server"
    ]
  },
  "prettier": {
    "printWidth": 130,
    "semi": false,
    "singleQuote": false,
    "trailingComma": "all"
  },
  "detox": {
    "test-runner": "jest",
    "configurations": {
      "ios.sim.debug": {
        "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/betterrail.app",
        "build": "xcodebuild -workspace ios/BetterRail.xcworkspace -scheme BetterRail -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build -destination 'name=iPhone 11'",
        "type": "ios.simulator",
        "name": "iPhone 11"
      },
      "ios.sim.release": {
        "binaryPath": "ios/build/Build/Products/Release-iphonesimulator/BetterRail.app",
        "build": "xcodebuild -workspace ios/BetterRail.xcworkspace -scheme BetterRail -configuration Release -sdk iphonesimulator -derivedDataPath ios/build -destination 'name=iPhone 11'",
        "type": "ios.simulator",
        "name": "iPhone 11"
      }
    }
  },
  "eslintConfig": {
    "root": true,
    "parser": "@typescript-eslint/parser",
    "extends": [
      "@react-native"
    ],
    "plugins": [
      "@typescript-eslint",
      "react",
      "react-native"
    ],
    "parserOptions": {
      "ecmaFeatures": {
        "jsx": true
      },
      "project": "./tsconfig.json"
    },
    "settings": {
      "react": {
        "pragma": "React",
        "version": "detect"
      }
    },
    "globals": {
      "__DEV__": false,
      "jasmine": false,
      "beforeAll": false,
      "afterAll": false,
      "beforeEach": false,
      "afterEach": false,
      "test": false,
      "expect": false,
      "describe": false,
      "jest": false,
      "it": false
    },
    "rules": {
      "@typescript-eslint/ban-ts-ignore": 0,
      "@typescript-eslint/explicit-function-return-type": 0,
      "@typescript-eslint/explicit-member-accessibility": 0,
      "@typescript-eslint/explicit-module-boundary-types": 0,
      "@typescript-eslint/indent": 0,
      "@typescript-eslint/member-delimiter-style": 0,
      "@typescript-eslint/no-empty-interface": 0,
      "@typescript-eslint/no-explicit-any": 0,
      "@typescript-eslint/no-object-literal-type-assertion": 0,
      "@typescript-eslint/no-var-requires": 0,
      "comma-dangle": 0,
      "multiline-ternary": 0,
      "no-undef": 0,
      "no-unused-vars": 0,
      "no-use-before-define": "off",
      "quotes": 0,
      "react-native/no-raw-text": 0,
      "react/no-unescaped-entities": 0,
      "react-native/split-platform-components": 0,
      "react/prop-types": "off",
      "space-before-function-paren": 0
    }
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@react-native-community/push-notification-ios",
          "@sentry/react-native",
          "react-native-push-notification",
          "react-native-default-preference",
          "@notifee/react-native",
          "posthog-react-native-session-replay",
          "react-native-prompt-android",
          "react-native-quick-actions-shortcuts"
        ]
      }
    }
  },
  "patchedDependencies": {
    "react-native-quick-actions-shortcuts@1.0.2": "patches/react-native-quick-actions-shortcuts@1.0.2.patch",
    "react-native-modal-datetime-picker@18.0.0": "patches/react-native-modal-datetime-picker@18.0.0.patch",
    "react-native-watch-connectivity@1.1.0": "patches/react-native-watch-connectivity@1.1.0.patch",
    "react-native-push-notification@8.1.1": "patches/react-native-push-notification@8.1.1.patch",
    "react-native-prompt-android@1.1.0": "patches/react-native-prompt-android@1.1.0.patch"
  }
}
