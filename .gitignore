# fastlane
#
# It is recommended to not store the screenshots in the git repo. Instead, use fastlane to re-generate the
# screenshots whenever they are needed.
# For more information about the recommended setup visit:
# https://docs.fastlane.tools/best-practices/source-control/

*/fastlane/report.xml
*/fastlane/Preview.html
*/fastlane/screenshots
**/fastlane/test_output

# Bundle artifact
*.jsbundle

# Ruby / CocoaPods
**/Pods/
/ios/GoogleService-Info.plist
/vendor/bundle/


# Ignite-specific items below
# You can safely replace everything above this comment with whatever is
# in the default .gitignore generated by React-Native CLI

# Expo
.expo/
bin/Exponent.app

# CNG (Continuous Native Generation): native projects are generated by `expo prebuild`.
# Source of truth is app.config.ts + ./plugins + ./targets. Do not commit these.
/ios
/android

# Production Firebase config (relocated to repo root; injected by CI / EAS secrets).
# The *.development.* variants ARE committed.
/GoogleService-Info.plist
/google-services.json

npm-debug.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/

# Environment files
.env
.env.local
.env.development
.env.production

# Configurations
app/config/env.*.js
!env.js
*.der
*.aab

# Temporary files created by Metro to check the health of the file watcher
.metro-health-check*
ios/fastlane/.env
.cursor/mcp.json
*.log

# apple-targets generated entitlements (regenerated each prebuild)
targets/**/generated.entitlements

# Expo export output (generated by `npx expo export`)
dist/

# Metro release bundler artifacts (regenerated at build time) — never commit under source.
# EXCEPTION: the station/railway widget drawables are referenced by native code
# (StationsData.kt R.drawable.assets_stationimages_*, widget_compact_*.xml
# @drawable/assets_railwaystation) and are NOT produced by a CNG/EAS debug build,
# so they must be committed as real native drawables.
android-native/res/drawable-*/assets_*
!android-native/res/drawable-*/assets_stationimages_*
!android-native/res/drawable-*/assets_railwaystation.*
android-native/res/drawable-*/node_modules_*
android-native/res/raw/assets_*

# apple-targets regenerates the watch app icon from targets/watch/icon.png each prebuild
targets/watch/Assets.xcassets/AppIcon.appiconset/
