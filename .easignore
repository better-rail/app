# EAS uses this instead of .gitignore when deciding what to copy into a build.
# It mirrors .gitignore, EXCEPT it does NOT ignore /google-services.json so that
# local prod builds (eas build --local) can consume the on-machine Firebase config
# via app.config.ts's fallback. Cloud builds still override it with the
# GOOGLE_SERVICES_JSON file secret, so including it here is harmless.

# OSX
.DS_Store

# Xcode
build/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata
*.xccheckout
*.moved-aside
DerivedData
*.hmap
*.ipa
*.dSYM.zip
*.xcuserstate
*.xcode.env.local

# Android/IntelliJ
build/
.idea
.gradle
local.properties
*.iml
*.hprof
.cxx/
*.keystore
!debug.keystore
/android/app/google-services.json
/android/app/release
/android/app/src/main/assets/index.android.bundle
/android/app/src/main/res/drawable-*/assets_*
/android/app/src/main/res/drawable-*/node_modules_*
/android/app/src/main/res/raw/assets_*
.kotlin/

# node.js
node_modules/
npm-debug.log
yarn-error.log
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# fastlane
*/fastlane/report.xml
*/fastlane/Preview.html
*/fastlane/screenshots
**/fastlane/test_output

# Bundle artifact
*.jsbundle

# Ruby / CocoaPods
**/Pods/
/ios/GoogleService-Info.plist
/vendor/bundle/

# Expo
.expo/
bin/Exponent.app

# CNG (Continuous Native Generation): native projects are generated by `expo prebuild`.
/ios
/android

# Production Firebase config.
# NOTE: /google-services.json is intentionally NOT ignored here (see header comment).
/GoogleService-Info.plist

npm-debug.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/

# Environment files
.env
.env.local
.env.development
.env.production

# Configurations
app/config/env.*.js
!env.js
*.der
*.aab

# Temporary files created by Metro to check the health of the file watcher
.metro-health-check*
ios/fastlane/.env
.cursor/mcp.json
*.log

# apple-targets generated entitlements (regenerated each prebuild)
targets/**/generated.entitlements

# Expo export output (generated by `npx expo export`)
dist/

# Metro release bundler artifacts (regenerated at build time).
android-native/res/drawable-*/assets_*
!android-native/res/drawable-*/assets_stationimages_*
!android-native/res/drawable-*/assets_railwaystation.*
android-native/res/drawable-*/node_modules_*
android-native/res/raw/assets_*

# apple-targets regenerates the watch app icon from targets/watch/icon.png each prebuild
targets/watch/Assets.xcassets/AppIcon.appiconset/
